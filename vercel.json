{
  "rewrites": [
    { "source": "/main", "destination": "/api/index.ts" },
    { "source": "/shop", "destination": "/api/index.ts" },
    { "source": "/callback", "destination": "/api/index.ts" },
    { "source": "/js/config.js", "destination": "/api/index.ts" },
    { "source": "/css/main.css", "destination": "/api/index.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
